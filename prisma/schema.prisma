generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Subscriber {
  id                 String    @id @default(cuid())
  email              String    @unique
  emailVerified      Boolean   @default(false)
  verificationToken  String?   @unique
  verificationExpiry DateTime?
  status             SubStatus @default(ACTIVE)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // OAuth connections
  linkedinAccessToken  String?
  linkedinUserId       String?
  linkedinTokenExpiry  DateTime?
  xAccessToken         String?
  xRefreshToken        String?
  xUserId              String?
  xTokenExpiry         DateTime?

  @@index([status])
  @@index([verificationToken])
}

model Newsletter {
  id          String           @id @default(cuid())
  title       String
  summary     String
  content     String
  imageUrl    String?
  status      NewsletterStatus @default(DRAFT)
  generatedAt DateTime         @default(now())
  sentAt      DateTime?

  @@index([status, generatedAt(sort: Desc)])
}

model OAuthState {
  id        String   @id @default(cuid())
  state     String   @unique
  provider  String
  userId    String
  codeVerifier String?
  createdAt DateTime @default(now())

  @@index([state])
}

enum SubStatus {
  ACTIVE
  UNSUBSCRIBED
  PENDING_VERIFICATION
}

enum NewsletterStatus {
  DRAFT
  PUBLISHED
  SENT
}
